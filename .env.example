# ============================================================
# Panifica — Variables de Entorno
# ============================================================
# COPIA este archivo como .env y completa los valores

# --- Servidor ---
PORT=3001
NODE_ENV=development

# --- API de IA (OpenAI o Anthropic) ---
# Elige UNA de las dos. La de OpenAI es más barata (gpt-4o-mini).
# Para OpenAI:
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-4o-mini

# Para Anthropic (Claude):
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-3-5-haiku-latest

# --- Google Sheets (Fase 2: migrar del parseo local) ---
# GOOGLE_SERVICE_ACCOUNT_EMAIL=...
# GOOGLE_PRIVATE_KEY=...
# GOOGLE_SPREADSHEET_ID=...

# --- WhatsApp Business API (Fase 3: webhook) ---
# WHATSAPP_VERIFY_TOKEN=...
# WHATSAPP_ACCESS_TOKEN=...
